; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="HoopClone"
config/description="Data-driven basketball simulation (Hoop Land-inspired)."
run/main_scene="res://game/main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[input]

move_left={
"deadzone": 0.2,
"events": []
}
move_right={
"deadzone": 0.2,
"events": []
}
move_up={
"deadzone": 0.2,
"events": []
}
move_down={
"deadzone": 0.2,
"events": []
}
shoot={
"deadzone": 0.2,
"events": []
}

[rendering]

environment/defaults/default_clear_color=Color(0.043, 0.055, 0.075, 1)
