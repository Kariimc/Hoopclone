# Godot — only the regenerable import CACHE is ignored; it rebuilds on open.
.godot/
export_presets.cfg

# Per-machine path to your Godot .exe for PLAY.bat (varies by computer).
godot-path.txt
# Godot engine that PLAY.bat downloads itself if none is installed (per-machine).
.godot-bin/

# Python
__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/

# Generated rosters (regenerate via export_roster.py); keep a sample if useful
# data/rosters/*.json

# ---------------------------------------------------------------------------
# Art/binary assets (.glb / .png / .jpeg) and their .import sidecars are now
# COMMITTED to the repo, NOT hand-placed. The GitHub repo is the single source
# of truth for every machine (cloud + laptop) — see docs/WORKFLOW.md.
